{
  "name": "lumiq",
  "private": true,
  "version": "0.1.0",
  "description": "Lumiq — live commerce moment vault. Independent frontend/ and backend/ projects.",
  "scripts": {
    "install:frontend": "npm --prefix frontend install",
    "dev": "npm --prefix frontend run dev",
