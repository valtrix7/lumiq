    "object_key": {
      "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/B2ObjectKey"
    },
    "mime_type": {
      "anyOf": [
        {
          "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/MimeType"
        },
        {
          "type": "null"
        }
      ]
    },
    "bytes": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "sha256": {
      "anyOf": [
        {
          "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/SHA256Digest"
        },
        {
          "type": "null"
        }
      ]
    },
    "b2_sha1": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "width": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "height": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 1
        },
        {
          "type": "null"
        }
      ]
    },
    "duration_ms": {
      "anyOf": [
        {
          "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/Milliseconds"
        },
        {
          "type": "null"
        }
      ]
    },
    "frame_count": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "null"
        }
      ]
    },
    "codec_video": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 80
        },
        {
          "type": "null"
        }
      ]
    },
    "codec_audio": {
      "anyOf": [
        {
          "type": "string",
          "maxLength": 80
        },
        {
          "type": "null"
        }
      ]
    },
    "retention_class": {
      "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/RetentionClass"
    },
    "verification_status": {
      "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/AssetVerificationStatus"
    },
    "is_deleted": {
      "type": "boolean"
    },
    "deleted_at": {
      "anyOf": [
        {
          "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/ISODateTime"
        },
        {
          "type": "null"
        }
      ]
    },
    "metadata_json": {
      "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/SafeMetadata"
    },
    "created_at": {
      "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/ISODateTime"
    },
    "updated_at": {
      "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/ISODateTime"
    }
  },
  "description": "B2-backed asset row/API contract. Canonical B2 objects are immutable and tenant-scoped.",
