    },
    "session_id": {
      "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/NullableULID"
    },
    "moment_id": {
      "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/NullableULID"
    },
