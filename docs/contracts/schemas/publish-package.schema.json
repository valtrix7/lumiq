            "internal_library",
            "download_zip",
            "signed_share_link",
            "tiktok_draft",
            "instagram_reels",
            "youtube_shorts",
            "shopify_media",
            "web"
          ]
        },
        "asset_id": {
          "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/ULID"
        },
        "format": {
          "type": "string",
          "enum": [
            "mp4",
            "webm",
            "jpg",
            "png",
            "vtt",
            "srt",
            "json",
            "zip"
          ]
        },
        "aspect_ratio": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "9:16",
                "1:1",
                "16:9"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "width": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "height": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "ready",
            "failed",
            "published",
            "revoked"
          ]
        }
      }
    },
    "ProductLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_id",
        "url"
      ],
      "properties": {
        "product_id": {
          "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/ULID"
        },
        "url": {
          "$ref": "https://schemas.lumiq.app/common.schema.json#/$defs/URI"
        },
        "label": {
          "anyOf": [
            {
              "type": "string",
              "maxLength": 120
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  },
