      "$value": "Inter",
      "$type": "fontFamily",
      "$description": "Primary UI font."
    },
    "mono": {
      "$value": "Geist Mono",
      "$type": "fontFamily",
      "$description": "Technical font for IDs, manifests, checksums, timestamps."
    }
  },
  "typography": {
