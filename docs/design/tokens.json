    },
    "xl": {
      "$value": "18px",
      "$type": "dimension"
    },
    "2xl": {
      "$value": "24px",
      "$type": "dimension"
    },
    "full": {
      "$value": "999px",
      "$type": "dimension"
    }
  },
  "layout": {
    "sidebar-width": {
      "$value": "248px",
      "$type": "dimension"
    },
    "topbar-height": {
      "$value": "64px",
      "$type": "dimension"
    },
    "workspace-max-width": {
      "$value": "1440px",
      "$type": "dimension"
    },
    "content-max-width": {
      "$value": "1280px",
      "$type": "dimension"
    }
  },
  "shadow": {
    "popover": {
      "$value": "0 16px 40px rgba(0, 0, 0, 0.42)",
      "$type": "shadow"
    },
    "modal": {
      "$value": "0 24px 80px rgba(0, 0, 0, 0.55)",
      "$type": "shadow"
    }
  },
  "motion": {
    "duration-fast": {
      "$value": "120ms",
      "$type": "duration"
    },
    "duration-base": {
      "$value": "180ms",
      "$type": "duration"
    },
    "duration-slow": {
      "$value": "280ms",
      "$type": "duration"
    },
    "ease-standard": {
      "$value": "cubic-bezier(0.2, 0, 0, 1)",
      "$type": "cubicBezier"
    },
    "ease-emphasized": {
      "$value": "cubic-bezier(0.16, 1, 0.3, 1)",
      "$type": "cubicBezier"
    }
  },
  "$extensions": {
    "lumiq.rules": {
      "theme": "dark-only",
      "gradientPolicy": "flat-only-no-glow-no-blur-no-aura",
      "logoDirection": "undecided",
      "primaryAccentRole": "actions-and-live-signal",
      "agentRule": "strict tokens plus documented exceptions"
    }
  }
