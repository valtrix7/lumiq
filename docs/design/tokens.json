{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Lumiq dark-only cinematic AI studio design tokens. Flat gradients only; no glow, no blur, no aura.",
  "brand": {
    "name": {
      "$value": "Lumiq",
      "$type": "string"
    },
    "direction": {
      "$value": "Dark cinematic AI studio with premium live-media intelligence and visible provenance.",
      "$type": "string"
    }
  },
  "color": {
    "canvas": {
      "$value": "#000000",
      "$type": "color",
      "$description": "Pure black cinematic media canvas."
    },
    "shell": {
      "$value": "#050506",
      "$type": "color",
      "$description": "Near-black app shell."
    },
    "panel": {
      "$value": "#0B0B0D",
      "$type": "color",
      "$description": "Workspace panel background."
    },
    "surface": {
      "one": {
        "$value": "#111114",
        "$type": "color",
        "$description": "Default dark card surface."
      },
      "two": {
        "$value": "#18181D",
        "$type": "color",
        "$description": "Raised/hover surface."
      },
      "three": {
        "$value": "#212129",
        "$type": "color",
        "$description": "Selected or high-emphasis surface."
      },
      "four": {
        "$value": "#292934",
        "$type": "color",
        "$description": "Floating popover/modal surface."
      }
    },
    "text": {
      "primary": {
        "$value": "#FFFFFF",
        "$type": "color"
      },
      "secondary": {
        "$value": "#B7B7C2",
        "$type": "color"
      },
      "muted": {
        "$value": "#8C8C99",
        "$type": "color"
      },
      "faint": {
        "$value": "#5E5E6B",
        "$type": "color"
      }
    },
    "accent": {
      "royal-blue": {
        "$value": "#365CFF",
        "$type": "color",
        "$description": "Primary action and live signal color."
      },
      "royal-blue-hover": {
        "$value": "#4C6DFF",
        "$type": "color"
      },
      "royal-blue-pressed": {
        "$value": "#2948D8",
        "$type": "color"
      },
      "royal-blue-soft": {
        "$value": "rgba(54, 92, 255, 0.14)",
        "$type": "color"
      }
    },
    "semantic": {
      "success": {
        "$value": "#7BE7A1",
        "$type": "color"
      },
      "warning": {
        "$value": "#FFD27A",
        "$type": "color"
      },
      "danger": {
        "$value": "#FF7A8A",
        "$type": "color"
      },
      "processing": {
        "$value": "#8FA4FF",
        "$type": "color"
      },
      "neutral": {
        "$value": "#B7B7C2",
        "$type": "color"
      }
    },
    "border": {
      "subtle": {
        "$value": "rgba(255, 255, 255, 0.08)",
        "$type": "color"
      },
      "medium": {
        "$value": "rgba(255, 255, 255, 0.14)",
        "$type": "color"
      },
      "strong": {
        "$value": "rgba(255, 255, 255, 0.22)",
        "$type": "color"
      }
    }
  },
  "gradient": {
    "spectral-pastel": {
      "$value": "linear-gradient(to right, #f6d1ac, #f3b5d2, #c7b8f5, #a7eadc, #afcdf6)",
      "$type": "gradient",
      "$description": "Primary flat Lumiq AI/brand gradient. Never blur or glow."
    },
    "ember-rose": {
      "$value": "linear-gradient(to right, #fc6767, #ec008c)",
      "$type": "gradient",
      "$description": "Rare high-energy marketing gradient. Not for errors or default CTAs."
    }
  },
  "font": {
